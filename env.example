OPENAI_API_KEY=<openai_api_key>
# # optional keys, when connecting to a Microsoft Dynamics 365 MCP Server
# ERP_MCP_TOKEN=<erp_mcp_token>
# AZ_USERNAME=<az_username>
# AZ_PASSWORD=<az_password>
# AZ_TENANT_ID=<az_tenant_id>
# # Optional: if set, inference will refuse to run when the az CLI is logged into this account
# ERP_BLOCKED_AZ_USER=